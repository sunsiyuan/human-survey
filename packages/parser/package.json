{
  "name": "@mts/parser",
  "version": "0.1.0",
  "description": "Markdown and JSON schema parser for Markdown to Survey — survey infrastructure for AI agents",
  "keywords": [
    "survey",
    "markdown",
    "parser",
    "json-schema",
    "questionnaire",
    "form",
    "ai-agent",
    "mcp",
    "typescript"
  ],
  "homepage": "https://mts.vercel.app",
  "repository": {
    "type": "git",
    "url": "https://github.com/sunsiyuan/markdown-to-survey"
  },
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts",
    "test": "vitest run",
    "dev": "tsup src/index.ts --format esm --dts --watch"
  },
  "dependencies": {
    "remark-parse": "^11",
    "unified": "^11",
    "nanoid": "^5"
  },
  "devDependencies": {
    "tsup": "^8",
    "vitest": "^3",
    "typescript": "^5"
  }
}
